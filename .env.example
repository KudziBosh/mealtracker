# Copy to .env and fill in. Never commit .env.

# Django
DJANGO_SETTINGS_MODULE=mealtracker.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_TIME_ZONE=Africa/Harare

# Database — used by Django and the postgres service in docker-compose
POSTGRES_DB=mealtracker
POSTGRES_USER=mealtracker
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (reserved for Celery in a later slice)
REDIS_URL=redis://redis:6379/0

# Telegram (deferred — leave blank for now)
TELEGRAM_BOT_TOKEN=

# docker compose — host port for the web service. Change if 8001 is taken.
WEB_HOST_PORT=8001
